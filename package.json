{
    "name": "wdio-mobile-tests",
    "version": "1.0.0",
    "description": "WebdriverIO Mobile App Testing with Appium — TypeScript",
    "scripts": {
        "test:android": "wdio run ./config/wdio.android.conf.ts",
        "test:ios": "wdio run ./config/wdio.ios.conf.ts",
        "test:android:smoke": "wdio run ./config/wdio.android.conf.ts --suite smoke",
        "test:ios:smoke": "wdio run ./config/wdio.ios.conf.ts --suite smoke",
        "test:bs:android": "wdio run ./config/wdio.browserstack.android.conf.ts",
        "test:bs:ios": "wdio run ./config/wdio.browserstack.ios.conf.ts",
        "allure:generate": "allure generate allure-results --clean -o allure-report",
        "allure:open": "allure open allure-report",
        "allure:report": "npm run allure:generate && npm run allure:open",
        "appium:install:drivers": "appium driver install uiautomator2 && appium driver install xcuitest",
        "appium:list": "appium driver list",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"**/*.{ts,js,json,yml,yaml,md}\"",
        "format:check": "prettier --check \"**/*.{ts,js,json,yml,yaml,md}\""
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.14.0",
        "@wdio/allure-reporter": "^8.40.0",
        "@wdio/appium-service": "^8.40.0",
        "@wdio/browserstack-service": "^9.29.1",
        "@wdio/cli": "^8.40.0",
        "@wdio/local-runner": "^8.40.0",
        "@wdio/mocha-framework": "^8.40.0",
        "@wdio/spec-reporter": "^8.40.0",
        "@wdio/types": "^8.40.0",
        "allure-commandline": "^2.30.0",
        "appium": "^2.11.0",
        "dotenv": "^16.4.5",
        "prettier": "^3.3.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.5"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
